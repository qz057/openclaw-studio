{
  "name": "openclaw-studio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.9.0",
  "scripts": {
    "build": "npm run build --workspace @openclaw/studio",
    "doctor": "npm run doctor --workspace @openclaw/studio",
    "icon:generate": "npm run icon:generate --workspace @openclaw/studio",
    "package:alpha": "npm run package:alpha --workspace @openclaw/studio",
    "package:smoke": "npm run package:smoke --workspace @openclaw/studio",
    "release:plan": "npm run release:plan --workspace @openclaw/studio",
    "smoke": "npm run smoke --workspace @openclaw/studio",
    "start:smoke": "npm run start:smoke --workspace @openclaw/studio",
    "typecheck": "npm run typecheck --workspace @openclaw/studio",
    "phase18:github-public-preview-pack": "npm run phase18:github-public-preview-pack --workspace @openclaw/studio",
    "phase19:github-release-staging": "npm run phase19:github-release-staging --workspace @openclaw/studio",
    "verify:product": "node scripts/verify-product.cjs",
    "start": "npm run start --workspace @openclaw/studio",
    "rebuild": "node scripts/rebuild.cjs",
    "check-env": "node scripts/check-env.cjs",
    "clean": "node scripts/clean-all.cjs"
  }
}
